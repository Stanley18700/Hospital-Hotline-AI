DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hospital_hotline
APP_NAME=Hospital Hotline Assistant API
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]
MOCK_NOTIFIER_ENABLED=true
NOTIFICATION_WEBHOOK_URL=
ALERT_SEVERITY_THRESHOLD=emergency
ALERT_COOLDOWN_SECONDS=300
GOOGLE_AI_ENABLED=true
# Switch google-genai (and ADK underneath it) to Vertex AI mode. When true,
# auth comes from GOOGLE_APPLICATION_CREDENTIALS + project/location below;
# no API key is needed. Set to false to use the Gemini API with GOOGLE_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Highest-quality GA Pro-tier text model on Vertex. ``gemini-3.1-pro-preview``
# is the absolute newest but is preview-gated per-project — swap to it only
# if your project's been allowlisted. For most standard Vertex projects,
# ``gemini-2.5-pro`` is the best model that "just works".
GOOGLE_MODEL_NAME=gemini-2.5-pro
# Gemini Live API model (voice WebSocket). Pro tier is NOT available for
# Live; this is the only GA Live-capable model on Vertex.
GOOGLE_LIVE_MODEL_NAME=gemini-live-2.5-flash-native-audio
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json